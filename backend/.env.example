SHAREPOINT_URL=https://seudominio.sharepoint.com/sites/exemplo

# ── Device Flow (dev com MFA) ──────────────────────────────────────────────
# Usa o client público do SharePoint Online Management Shell (sem App Registration)
DEVICE_FLOW_TENANT=seudominio.onmicrosoft.com
# DEVICE_FLOW_CLIENT_ID=9bc3ab49-b65d-410a-85ad-de819febfddc  # padrão Microsoft, trocar se tiver App Registration próprio

# ── Modo produção ──
# CLIENT_ID=xxxx
# CLIENT_SECRET=xxxx
# TENANT_ID=xxxx

# ── Modo dev sem MFA (não recomendado em produção) ──
# SP_USERNAME=seuemail@sesisenai.com.br
# SP_PASSWORD=suasenha
